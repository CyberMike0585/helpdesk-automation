---offbaorading users script 



#!/bin/bash

if [ -z "$1" ]; then
    echo "Usage: $0 username"
    exit 1
fi

USERNAME=$1
ARCHIVE_DIR="/home/I.T-Mike/helpdesk-automation/archived_users"
LOGFILE="/var/log/onboarding.log"

sudo mkdir -p "$ARCHIVE_DIR"

if id "$USERNAME" &>/dev/null; then
    sudo usermod -L "$USERNAME"
    sudo tar -czf "$ARCHIVE_DIR/${USERNAME}_home_$(date +%F).tar.gz" "/home/$USERNAME" 2>/dev/null
    echo "$(date) - Offboarded user: $USERNAME" | sudo tee -a "$LOGFILE" >/dev/null
    echo "User $USERNAME locked and home directory archived."
else
    echo "User $USERNAME does not exist."
fi


