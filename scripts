-----system health check script a




#!/bin/bash

LOGFILE="$HOME/helpdesk-automation/health_report.log"
DATE=$(date)

echo "============================" >> "$LOGFILE"
echo "System Health Report - $DATE" >> "$LOGFILE"
echo "============================" >> "$LOGFILE"

echo "" >> "$LOGFILE"
echo "Hostname:" >> "$LOGFILE"
hostnamectl --static >> "$LOGFILE"

echo "" >> "$LOGFILE"
echo "Uptime:" >> "$LOGFILE"
uptime >> "$LOGFILE"

echo "" >> "$LOGFILE"
echo "Memory Usage:" >> "$LOGFILE"
free -h >> "$LOGFILE"

echo "" >> "$LOGFILE"
echo "Disk Usage:" >> "$LOGFILE"
df -h >> "$LOGFILE"

echo "" >> "$LOGFILE"
echo "Top 5 CPU Processes:" >> "$LOGFILE"
ps -eo pid,ppid,cmd,%mem,%cpu --sort=-%cpu | head -n 6 >> "$LOGFILE"

echo "" >> "$LOGFILE"
echo "Top 5 Memory Processes:" >> "$LOGFILE"
ps -eo pid,ppid,cmd,%mem,%cpu --sort=-%mem | head -n 6 >> "$LOGFILE"

echo "" >> "$LOGFILE"
echo "Active Failed Services:" >> "$LOGFILE"
systemctl --failed >> "$LOGFILE"

echo "" >> "$LOGFILE"
echo "Health check completed."






















